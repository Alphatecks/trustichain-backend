# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cardyfie (virtual card API - sandbox)
# Get from: Cardyfie Dashboard → Api Credentials → Create App
CARDYFIE_API_KEY=

# Optional - other env vars used in the project
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=
# XUMM_API_KEY=
# XUMM_API_SECRET=
# XRPL_NETWORK=testnet
# MULTICHAIN_NETWORK=testnet
#   testnet: USDT ERC20=Sepolia, TRC20=Shasta, BEP20=BSC testnet; USDC BEP20=BSC testnet, SOLANA=devnet
#   mainnet: production chains
# CRON_SECRET=  # Required for POST /api/cron/sync-multichain-deposits (schedule every 1-5 min)
# Optional RPC overrides (defaults work for testnet):
# ETH_SEPOLIA_RPC_URL=  BSC_TESTNET_RPC_URL=  SOLANA_DEVNET_RPC_URL=  TRON_SHASTA_API_URL=
# TRONGRID_API_KEY=  # optional, higher TronGrid rate limits
# USDT_ERC20_CONTRACT_TESTNET=  USDT_BEP20_CONTRACT_TESTNET=  USDT_TRC20_CONTRACT_TESTNET=
# USDC_BEP20_CONTRACT_TESTNET=  USDC_SOLANA_MINT_TESTNET=
# ENCRYPTION_KEY=  # Required for custodial XRPL + multichain deposit address secrets
# MFA_ENCRYPTION_KEY=  # Required for Google Authenticator / TOTP (64 hex chars = 32 bytes). Generate: openssl rand -hex 32
# MFA_APP_NAME=TrustiChain  # Shown in authenticator app
# MFA_TOTP_WINDOW_STEPS=2  # Clock drift tolerance (each step = 30s)
# Stripe (test mode)
# STRIPE_TEST_MODE=true
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
